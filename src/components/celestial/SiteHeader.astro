---
import LanguageBar from "@/components/selectors/LanguageBar.astro";
import MoodBar from "@/components/selectors/MoodBar.astro";
import ConnectionModeBadge from "@/components/celestial/ConnectionModeBadge.astro";
import type { Lang, Mood } from "@/lib/domain/types";

const { currentLang, currentMood } = Astro.props;
---

<header
  data-site-header
  class="refugio-sticky-nav fixed top-0 right-0 left-0 z-50 border-b border-gold-500/20 bg-transparent pt-[env(safe-area-inset-top,0px)] backdrop-blur-md supports-[backdrop-filter]:bg-black/[0.04]"
  aria-label="Categoría e idioma"
>
  <div
    class="relative mx-auto flex min-h-[2.875rem] w-full max-w-[1600px] flex-row items-center gap-3 px-3 py-3 sm:min-h-12 sm:gap-4 sm:px-5 sm:py-3.5 md:grid md:min-h-0 md:grid-cols-[minmax(0,1fr)_auto_minmax(0,1fr)] md:items-center md:gap-x-5 md:gap-y-0 md:px-6 md:py-4 lg:gap-x-8 lg:px-10 lg:py-4"
  >
    <div class="hidden min-w-0 md:flex md:items-center md:gap-2" aria-hidden="true">
      <div class="relative h-10 w-10 lg:h-11 lg:w-11">
        <img
          data-site-brand-dove
          src="/img/paloma-top.png"
          alt=""
          aria-hidden="true"
          class="absolute inset-0 h-full w-full object-contain opacity-0 transition-all duration-200"
          loading="lazy"
        />
        <img
          data-site-brand-logo
          src="/img/logo-refugio-celestial-best.png"
          alt="Logo Refugio Celestial"
          class="absolute inset-0 h-full w-full rounded-full border border-gold-500/30 object-cover opacity-100 transition-all duration-200"
          loading="lazy"
        />
      </div>
      <p class="font-display text-[10px] font-semibold uppercase leading-tight tracking-[0.12em] text-gold-200/85 lg:text-xs">
        <span class="block">Versículos</span>
        <span class="block">Bíblicos</span>
      </p>
    </div>

    <!-- Móvil: logo + nombre de app -->
    <div class="shrink-0 md:hidden flex items-center gap-2">
      <div class="relative h-9 w-9">
        <img
          data-site-brand-dove
          src="/img/paloma-top.png"
          alt=""
          aria-hidden="true"
          class="absolute inset-0 h-full w-full object-contain opacity-0 transition-all duration-200"
          loading="lazy"
        />
        <img
          data-site-brand-logo
          src="/img/logo-refugio-celestial-best.png"
          alt="Logo Refugio Celestial"
          class="absolute inset-0 h-full w-full rounded-full border border-gold-500/30 object-cover opacity-100 transition-all duration-200"
          loading="lazy"
        />
      </div>
      <p class="font-display text-[10px] font-semibold uppercase leading-tight tracking-[0.12em] text-gold-200/85">
        <span class="block">Versículos</span>
        <span class="block">Bíblicos</span>
      </p>
    </div>

    <!-- Móvil: filtro alineado a la derecha | PC: columna central -->
    <div
      class="ml-auto min-w-0 flex-none md:ml-0 md:col-span-1 md:col-start-2 md:flex md:max-w-[min(100%,58rem)] md:flex-none md:justify-self-center"
    >
      <div
        class="pointer-events-auto w-auto min-w-0 md:flex md:w-auto md:max-w-none md:justify-center"
      >
        <MoodBar currentLang={currentLang} currentMood={currentMood} />
      </div>
    </div>

    <!-- Móvil: switch a la derecha junto al filtro | PC: tercera columna -->
    <div class="shrink-0 flex items-center gap-2 md:col-start-3 md:justify-self-end">
      <div class="hidden sm:block">
        <ConnectionModeBadge />
      </div>
      <LanguageBar currentMood={currentMood} />
    </div>
  </div>
</header>

<script is:inline>
  (() => {
    const root = document.querySelector("[data-site-header]");
    if (!root) return;
    const mql = window.matchMedia("(min-width: 768px)");

    const onScroll = () => {
      // On mobile we keep the header logo stable to avoid flicker.
      if (!mql.matches) {
        root.classList.remove("is-scrolled");
        return;
      }
      root.classList.toggle("is-scrolled", window.scrollY > 26);
    };

    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });
    mql.addEventListener?.("change", onScroll);
  })();
</script>

<style>
  @media (min-width: 768px) {
    [data-site-header].is-scrolled [data-site-brand-dove] {
      opacity: 1;
      transform: scale(0.88);
    }

    [data-site-header].is-scrolled [data-site-brand-logo] {
      opacity: 0;
      transform: scale(1);
    }
  }
</style>
