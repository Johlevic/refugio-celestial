---
import BaseLayout from "@/components/layout/BaseLayout.astro";
import CosmicBackground from "@/components/celestial/CosmicBackground";
---

<BaseLayout
  title="500 — Versículos Bíblicos"
  description="Ocurrió un problema inesperado en la aplicación."
  lang="es"
>
  <CosmicBackground client:idle />
  <main class="relative z-10 mx-auto flex min-h-dvh max-w-3xl items-center justify-center px-4 py-10">
    <section class="w-full max-w-xl rounded-2xl border border-gold-500/25 bg-[#0e132d]/70 p-6 text-center shadow-[0_0_22px_rgba(0,0,0,0.35)] backdrop-blur-sm sm:p-8">
      <img
        src="/img/logo-refugio-celestial-best.png"
        alt="Versículos Bíblicos"
        class="mx-auto mb-4 h-16 w-16 rounded-full border border-gold-500/30 object-cover"
      />
      <p class="font-display text-3xl font-bold tracking-[0.12em] text-gold-200 sm:text-4xl">500</p>
      <p class="mt-3 text-base text-gold-100/90 sm:text-lg">Tuvimos un problema interno.</p>
      <p class="mt-2 text-sm text-gold-300/70">Intenta de nuevo en unos segundos.</p>
      <div class="mt-6 flex items-center justify-center gap-3">
        <a
          href="/"
          class="inline-flex min-h-11 items-center justify-center rounded-full border border-gold-500/40 bg-gold-500/10 px-6 py-2 text-sm font-semibold text-gold-100 transition hover:border-gold-400 hover:bg-gold-500/20"
        >
          Ir al inicio
        </a>
        <button
          type="button"
          onclick="window.location.reload()"
          class="inline-flex min-h-11 items-center justify-center rounded-full border border-gold-500/25 bg-black/25 px-5 py-2 text-sm font-semibold text-gold-100/90 transition hover:border-gold-500/40 hover:bg-black/35"
        >
          Reintentar
        </button>
      </div>
    </section>
  </main>
</BaseLayout>
