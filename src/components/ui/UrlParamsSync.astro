---

<script is:inline>
  (function () {
    const MOOD_LABELS = {
      es: {
        all: "Todos",
        comfort: "Consuelo",
        wisdom: "Sabiduría",
        hope: "Esperanza",
        love: "Amor",
        repentance: "Perdón",
      },
      en: {
        all: "All",
        comfort: "Comfort",
        wisdom: "Wisdom",
        hope: "Hope",
        love: "Love",
        repentance: "Forgiveness",
      },
    };
    const MOODS = new Set([
      "all",
      "comfort",
      "wisdom",
      "hope",
      "love",
      "repentance",
    ]);

    function applyFromQuery() {
      const q = new URLSearchParams(window.location.search);
      const lang = q.get("lang") === "en" ? "en" : "es";
      const raw = q.get("mood");
      const mLower = raw ? raw.toLowerCase() : "";
      const mood = mLower && MOODS.has(mLower) ? mLower : "all";

      document.documentElement.setAttribute("data-url-lang", lang);
      document.documentElement.setAttribute("data-url-mood", mood);

      const hM = document.getElementById("refugio-hidden-mood");
      if (hM && hM instanceof HTMLInputElement) hM.value = mood;

      document.querySelectorAll("input.refugio-mood-lang").forEach(function (el) {
        if (el instanceof HTMLInputElement) el.value = lang;
      });

      const labels = MOOD_LABELS[lang];
      const mobileCurrent = document.querySelector("[data-mood-mobile-current]");
      if (mobileCurrent && Object.prototype.hasOwnProperty.call(labels, mood)) {
        mobileCurrent.textContent = labels[mood];
      }
      const mobileHidden = document.getElementById("refugio-mood-mobile-value");
      if (mobileHidden && mobileHidden instanceof HTMLInputElement) {
        mobileHidden.value = mood;
      }
      document.querySelectorAll("[data-mood-sheet-label]").forEach(function (el) {
        const key = el.getAttribute("data-mood-sheet-label");
        if (key && Object.prototype.hasOwnProperty.call(labels, key)) {
          el.textContent = labels[key];
        }
      });
      document.querySelectorAll("[data-mood-sheet-btn]").forEach(function (el) {
        const key = el.getAttribute("data-mood-sheet-btn");
        el.classList.toggle("is-active", key === mood);
      });
      const openBtn = document.querySelector("[data-mood-open]");
      if (openBtn) {
        openBtn.classList.toggle("is-filter-active", mood !== "all");
      }

      document.querySelectorAll("[data-lang-btn]").forEach(function (b) {
        const v = b.getAttribute("data-lang-btn");
        b.classList.toggle("nav-active", v === lang);
        b.setAttribute("aria-pressed", v === lang ? "true" : "false");
      });
      document.querySelectorAll("[data-mood-btn]").forEach(function (b) {
        const v = b.getAttribute("data-mood-btn");
        if (v && Object.prototype.hasOwnProperty.call(labels, v)) {
          const labelNode = Array.from(b.childNodes).find(
            (n) => n.nodeType === Node.TEXT_NODE && n.textContent && n.textContent.trim().length > 0,
          );
          if (labelNode) {
            labelNode.textContent = " " + labels[v];
          }
        }
        b.classList.toggle("nav-active", v === mood);
        b.setAttribute("aria-pressed", v === mood ? "true" : "false");
      });
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", applyFromQuery);
    } else {
      applyFromQuery();
    }
  })();
</script>

<style is:global>
  [data-mood-btn].nav-active {
    border-color: #e8c547 !important;
    background: linear-gradient(180deg, #e4c04a, #c9a227) !important;
    color: #0a0b14 !important;
    font-weight: 700 !important;
    box-shadow: none !important;
  }
  [data-mood-btn].nav-active i {
    color: #0a0b14;
    opacity: 1 !important;
  }
  [data-lang-btn].nav-active {
    border-color: #e8c547 !important;
    background: linear-gradient(180deg, #e4c04a, #c9a227) !important;
    color: #0a0b14 !important;
    font-weight: 800 !important;
    box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.1) !important;
  }
  html[data-url-lang="en"] .i18n-es {
    display: none !important;
  }
  html[data-url-lang="en"] .i18n-en {
    display: inline !important;
  }
  html[data-url-lang="es"] .i18n-en {
    display: none !important;
  }
  html[data-url-lang="es"] .i18n-es {
    display: inline !important;
  }
</style>
