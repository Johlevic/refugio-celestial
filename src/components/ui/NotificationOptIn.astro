<div
  id="refugio-notif-optin"
  class="fixed bottom-3 left-1/2 z-[85] hidden w-[min(92vw,28rem)] -translate-x-1/2 rounded-xl border border-gold-500/35 bg-[#0e132d]/92 p-3 text-gold-100 shadow-[0_8px_28px_rgba(0,0,0,0.4)] backdrop-blur-sm"
>
  <p class="text-sm font-semibold">Activa recordatorios de versículos</p>
  <p class="mt-1 text-xs text-gold-200/80">
    Te enviaremos un recordatorio diario por la mañana con un versículo.
  </p>
  <div class="mt-3 flex items-center gap-2">
    <button
      id="refugio-notif-enable"
      type="button"
      class="inline-flex min-h-10 items-center justify-center rounded-full border border-gold-500/45 bg-gold-500/10 px-4 text-xs font-semibold text-gold-100 transition hover:bg-gold-500/20"
    >
      Activar
    </button>
    <button
      id="refugio-notif-dismiss"
      type="button"
      class="inline-flex min-h-10 items-center justify-center rounded-full border border-gold-500/25 bg-black/25 px-4 text-xs font-semibold text-gold-100/90 transition hover:bg-black/35"
    >
      Ahora no
    </button>
  </div>
</div>

<script is:inline>
  (function () {
    if (typeof window === "undefined" || !("Notification" in window)) return;

    const KEY_ENABLED = "refugio.notifications.enabled";
    const KEY_LAST_SENT_DAY = "refugio.notifications.lastSentDay";
    const KEY_DISMISSED = "refugio.notifications.dismissedAt";
    const PROMPT_COOLDOWN_MS = 1000 * 60 * 60 * 24 * 2; // 2 days
    const MORNING_START_HOUR = 7;
    const MORNING_END_HOUR = 11;

    const panel = document.getElementById("refugio-notif-optin");
    const btnEnable = document.getElementById("refugio-notif-enable");
    const btnDismiss = document.getElementById("refugio-notif-dismiss");
    if (!panel || !btnEnable || !btnDismiss) return;

    const messages = [
      "“Este es el día que hizo Jehová; nos gozaremos y alegraremos en él.” — Salmo 118:24",
      "“En paz me acostaré, y asimismo dormiré; porque solo tú, Jehová, me haces vivir confiado.” — Salmo 4:8",
      "“Por la misericordia de Jehová no hemos sido consumidos... nuevas son cada mañana.” — Lamentaciones 3:22-23",
      "“Porque yo sé los pensamientos que tengo acerca de vosotros, dice Jehová...” — Jeremías 29:11",
    ];

    const now = () => new Date();
    const dayKey = (d) => {
      const y = d.getFullYear();
      const m = String(d.getMonth() + 1).padStart(2, "0");
      const da = String(d.getDate()).padStart(2, "0");
      return `${y}-${m}-${da}`;
    };

    function isMorning(d) {
      const h = d.getHours();
      return h >= MORNING_START_HOUR && h < MORNING_END_HOUR;
    }

    function maybeNotify() {
      if (Notification.permission !== "granted") return;
      if (localStorage.getItem(KEY_ENABLED) !== "1") return;
      const d = now();
      if (!isMorning(d)) return;
      const today = dayKey(d);
      if (localStorage.getItem(KEY_LAST_SENT_DAY) === today) return;

      const body = messages[Math.floor(Math.random() * messages.length)] || messages[0];
      const n = new Notification("BVerses", {
        body,
        icon: "/img/logo-refugio-celestial-best.png",
        badge: "/img/logo-refugio-celestial-best.png",
      });
      n.onclick = () => {
        window.focus();
        window.location.href = "/";
      };
      localStorage.setItem(KEY_LAST_SENT_DAY, today);
    }

    function hidePrompt() {
      panel.classList.add("hidden");
    }

    function showPrompt() {
      panel.classList.remove("hidden");
    }

    const dismissedAt = Number(localStorage.getItem(KEY_DISMISSED) || "0");
    const enabled = localStorage.getItem(KEY_ENABLED) === "1";

    if (!enabled && Notification.permission === "default") {
      if (!dismissedAt || now() - dismissedAt > PROMPT_COOLDOWN_MS) showPrompt();
    }

    btnEnable.addEventListener("click", async function () {
      const p = await Notification.requestPermission();
      if (p === "granted") {
        localStorage.setItem(KEY_ENABLED, "1");
        maybeNotify();
      }
      hidePrompt();
    });

    btnDismiss.addEventListener("click", function () {
      localStorage.setItem(KEY_DISMISSED, String(now()));
      hidePrompt();
    });

    // Check periodically and trigger once per morning/day.
    setInterval(maybeNotify, 60 * 1000);
    maybeNotify();
  })();
</script>
