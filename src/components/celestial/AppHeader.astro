<div 
  data-app-header
  class="app-title text-center max-md:flex max-md:min-h-[clamp(6rem,18vh,10rem)] max-md:flex-col max-md:justify-center max-md:py-[clamp(0.75rem,2.6vh,1.5rem)] sm:py-4" 
  role="group" 
  aria-label="Título del sitio"
>
  <!-- Subtítulo con animación sutil -->
  <p class="
    mb-[clamp(0.15rem,0.8vh,0.45rem)] sm:mb-0.5
    font-sans text-[11px] font-medium
    uppercase leading-tight 
    tracking-[0.25em]
    text-gold-400/60
    sm:text-xs sm:tracking-[0.3em]
    transition-colors duration-300
    hover:text-gold-300/80
  ">
    <span class="i18n-es">Refugio celestial</span>
    <span class="i18n-en hidden" aria-hidden="true">Celestial refuge</span>
  </p>

  <!-- Contenedor de título -->
  <div class="
    mx-auto flex max-w-md items-center justify-center gap-3 
    max-md:mt-[clamp(0.25rem,1vh,0.5rem)]
    sm:max-w-lg sm:gap-4
  ">
    <!-- Título con gradiente de texto -->
    <h1 class="
      font-display 
      text-xl sm:text-2xl md:text-3xl
      font-bold 
      uppercase leading-none
      tracking-[0.12em]
      bg-gradient-to-b from-gold-50 via-gold-200 to-gold-400
      bg-clip-text text-transparent
      transition-opacity duration-300
      cursor-default select-none
    ">
      <span class="i18n-es">Alimento para el alma</span>
      <span class="i18n-en hidden" aria-hidden="true">Nourishment for the soul</span>
    </h1>
  </div>

  <div data-app-header-dove class="mt-3 flex justify-center sm:mt-4">
    <img
      src="/img/paloma-top.png"
      alt=""
      aria-hidden="true"
      class="h-28 w-28 object-contain opacity-95 sm:h-32 sm:w-32"
      loading="lazy"
    />
  </div>

  <!-- Línea decorativa inferior (debajo de la paloma) -->
  <div data-app-header-divider class="mx-auto mt-1 h-px w-32 bg-gradient-to-r from-transparent via-gold-500/30 to-transparent sm:mt-1.5 sm:w-48" />
</div>

<script is:inline>
  (() => {
    const root = document.querySelector("[data-app-header]");
    if (!root) return;
    const mql = window.matchMedia("(min-width: 768px)");

    const onScroll = () => {
      if (!mql.matches) {
        root.classList.remove("is-scrolled");
        return;
      }
      const scrolled = window.scrollY > 26;
      root.classList.toggle("is-scrolled", scrolled);
    };

    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });
    mql.addEventListener?.("change", onScroll);
  })();
</script>

<style>
  @media (min-width: 768px) {
    .app-title [data-app-header-dove],
    .app-title [data-app-header-divider] {
      transition: opacity 220ms ease, transform 220ms ease, max-height 220ms ease, margin 220ms ease;
      transform-origin: top center;
    }

    .app-title.is-scrolled [data-app-header-dove] {
      opacity: 0;
      transform: scale(0.88);
      max-height: 0;
      margin-top: 0;
      overflow: hidden;
      pointer-events: none;
    }

    .app-title.is-scrolled [data-app-header-divider] {
      opacity: 0.25;
      margin-top: 0;
    }
  }
</style>
